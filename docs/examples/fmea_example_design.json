{
  "minds": [
    {
      "uuid": "a1b2c3d4-0001-4000-8000-000000000001",
      "mind_type": "Requirement",
      "title": "Motor Assembly Reliability",
      "version": 1,
      "created_at": "2024-06-01T08:00:00Z",
      "updated_at": "2024-06-01T08:00:00Z",
      "creator": "fmea-example@example.com",
      "status": "active",
      "description": "The motor assembly shall operate reliably for a minimum of 20,000 hours under rated load without degradation beyond acceptable limits.",
      "tags": [
        "design-fmea",
        "motor",
        "reliability"
      ],
      "type_specific_attributes": {
        "requirement_type": "DESIGN_INPUT",
        "content": "Motor assembly shall achieve MTBF >= 20,000 hours at rated load and ambient temperature range -20C to +55C.",
        "source": "Product Requirements Document v2.1",
        "acceptance_criteria": "No bearing or winding failures during accelerated life testing equivalent to 20,000 hours.",
        "compliance_standard": "IEC 60034-1",
        "safety_critical": false
      }
    },
    {
      "uuid": "a1b2c3d4-0001-4000-8000-000000000002",
      "mind_type": "Requirement",
      "title": "Control System Safety",
      "version": 1,
      "created_at": "2024-06-01T08:00:00Z",
      "updated_at": "2024-06-01T08:00:00Z",
      "creator": "fmea-example@example.com",
      "status": "active",
      "description": "The electronic control system shall maintain safe operation under all single-fault conditions and fail to a safe state.",
      "tags": [
        "design-fmea",
        "control-system",
        "safety"
      ],
      "type_specific_attributes": {
        "requirement_type": "DESIGN_INPUT",
        "content": "Control system shall detect faults within 50ms and transition to safe state within 200ms of fault detection.",
        "source": "Functional Safety Specification v1.3",
        "acceptance_criteria": "All single-point faults detected and mitigated during FMEA review and hardware-in-the-loop testing.",
        "compliance_standard": "IEC 61508 SIL 2",
        "safety_critical": true
      }
    },
