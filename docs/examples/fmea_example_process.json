    {
      "uuid": "b1b2c3d4-0001-4000-8000-000000000001",
      "mind_type": "Requirement",
      "title": "PCB Soldering Quality",
      "version": 1,
      "created_at": "2024-07-01T08:00:00Z",
      "updated_at": "2024-07-01T08:00:00Z",
      "creator": "fmea-process@example.com",
      "status": "active",
      "description": "All PCB solder joints shall meet IPC-A-610 Class 3 acceptance criteria with zero defects escaping to final test.",
      "tags": [
        "process-fmea",
        "pcb",
        "soldering"
      ],
      "type_specific_attributes": {
        "requirement_type": "DESIGN_INPUT",
        "content": "PCB assemblies shall achieve a first-pass yield of >= 99.5% at in-circuit test with no solder defects classified as IPC-A-610 Class 3 rejects.",
        "source": "Manufacturing Quality Plan MQP-2024-003",
        "acceptance_criteria": "Zero Class 3 solder defects per 10,000 joints measured over a rolling 30-day window.",
        "compliance_standard": "IPC-A-610 Rev H Class 3",
        "safety_critical": false
      }
    },
    {
      "uuid": "b1b2c3d4-0001-4000-8000-000000000002",
      "mind_type": "Requirement",
      "title": "Final Assembly Torque Specification",
      "version": 1,
      "created_at": "2024-07-01T08:00:00Z",
      "updated_at": "2024-07-01T08:00:00Z",
      "creator": "fmea-process@example.com",
      "status": "active",
      "description": "All threaded fasteners in the final assembly shall be torqued to specification and verified to prevent loosening under operational vibration.",
      "tags": [
        "process-fmea",
        "assembly",
        "torque"
      ],
      "type_specific_attributes": {
        "requirement_type": "DESIGN_INPUT",
        "content": "All critical fasteners shall be torqued within +/-5% of nominal specification and verified via torque audit sampling at 100% for safety-critical joints.",
        "source": "Assembly Work Instruction AWI-FA-0012 Rev C",
        "acceptance_criteria": "Torque audit pass rate >= 99.8% with no safety-critical fastener failures.",
        "compliance_standard": "ISO 5393",
        "safety_critical": true
      }
    },
